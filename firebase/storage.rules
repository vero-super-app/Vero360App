rules_version = '2';
// Deploy: firebase deploy --only storage
// Specific paths first; default deny at the bottom matches production lock-down.

service firebase.storage {
  match /b/{bucket}/o {
    // Courier delivery proof photos
    match /delivery_proofs/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Profile / merchant images (marketplace, accommodation, etc.)
    // Filename must start with the uploader's Firebase uid + "_"
    match /profile_photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && fileName.matches('^' + request.auth.uid + '_.*');
    }

    match /accommodation_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat images and attachments
    match /chat_media/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Voice notes in chat
    match /voice_notes/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else (production default)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
